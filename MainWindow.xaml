<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="145"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Nom -->
        <Label Grid.Row="0" Grid.Column="0"
               Content="Entrez votre nom :" />
        <TextBox Grid.Row="0" Grid.Column="1"
                 x:Name="TxtNom"/>

        <!-- Row 2: Fonction -->
        <Label Grid.Row="2" Grid.Column="0"
               Content="Entrez votre fonction :" />
        <ComboBox Grid.Row="2" Grid.Column="1"
                  x:Name="CmbFonction" 
                  IsEditable="False">
            <ComboBoxItem Content="Développeur"/>
            <ComboBoxItem Content="Designer"/>
            <ComboBoxItem Content="Chef de projet"/>
            <ComboBoxItem Content="Analyste"/>
            <ComboBoxItem Content="Administrateur"/>
        </ComboBox>

        <!-- Row 4: Status + Button -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="TxtStatus"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       FontStyle="Italic"
                       Foreground="Gray"
                       Text="..."/>
            <Button x:Name="BtnBienvenue"
                    Content="Bienvenue"
                    Width="100"
                    Height="26"
                    Click="BtnBienvenue_Click"/>
        </StackPanel>
    </Grid>
</Window>
